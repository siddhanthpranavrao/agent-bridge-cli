{
  "name": "agent-bridge-cli",
  "version": "0.1.5",
  "description": "Let multiple Claude Code instances communicate without polluting each other's context",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "agent-bridge": "dist/index.js"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build --target=node --external @anthropic-ai/claude-agent-sdk --external zod ./src/index.ts --outfile=dist/index.js",
    "test": "bun test",
    "postinstall": "node -e \"const fs=require('fs'),p=require('path'),d=p.join(require('os').homedir(),'.claude','skills','bridge');fs.mkdirSync(d,{recursive:true});fs.copyFileSync(p.join(__dirname,'skill','SKILL.md'),p.join(d,'SKILL.md'))\"",
    "preuninstall": "node -e \"try{require('fs').rmSync(require('path').join(require('os').homedir(),'.claude','skills','bridge'),{recursive:true})}catch{}\""
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "files": [
    "dist/**/*.js",
    "skill/**/*.md"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/siddhanthpranavrao/agent-bridge-cli.git"
  }
}
